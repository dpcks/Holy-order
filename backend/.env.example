# Holy-Order Backend Environment Variables

# [Database Setting]
# Railway에서 제공하는 PostgreSQL URL을 입력합니다. (실제 배포 환경에서 주입)
# 로컬 개발 시에는 로컬 DB URL을 사용하세요.
DATABASE_URL=postgresql://user:password@localhost:5432/holyorder

# [Security Setting]
# JWT 토큰 암호화에 사용되는 시크릿 키입니다.
# 배포 전 터미널에서 `openssl rand -hex 32`를 실행하여 나온 값을 입력하세요.
SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# [CORS Setting]
# 허용할 프론트엔드 도메인 주소 목록입니다. (JSON 형식의 문자열이어야 합니다)
# Vercel 배포 후 발급받은 도메인을 추가하세요.
CORS_ORIGINS=["http://localhost:5173", "https://your-vercel-domain.vercel.app"]
