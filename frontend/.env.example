# Holy-Order Frontend Environment Variables

# [API Server Setting]
# 백엔드 서버의 주소를 입력합니다. 
# 로컬 개발 시: 미설정 시 기본값(http://localhost:8000/api/v1)으로 동작합니다.
# Vercel 배포 시: Railway에 배포된 백엔드 도메인(예: https://api.holyorder.com/api/v1)을 입력하세요.
VITE_API_BASE_URL=

# [WebSocket Setting]
# WebSocket 연결 주소를 입력합니다.
# 로컬 개발 시: 미설정 시 기본값(ws://localhost:8000/ws)으로 동작합니다.
# Vercel 배포 시: Railway 백엔드 도메인을 wss 프로토콜로 입력하세요. (예: wss://api.holyorder.com/ws)
VITE_WS_URL=

# [Cloudinary Setting (Image/Audio Storage)]
# Cloudinary 연동을 위한 환경변수입니다. 대시보드에서 확인 가능합니다.
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_name
